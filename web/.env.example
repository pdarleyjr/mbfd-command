# ─────────────────────────────────────────────────────────────────────────────
# MBFD Command — frontend environment (Vite). Copy to `.env.local` for local dev.
# These VITE_* vars are PUBLIC (baked into the client bundle). Never put secrets
# (tokens, private keys) in VITE_* vars — the radio backend holds those.
# ─────────────────────────────────────────────────────────────────────────────

# Google Maps JavaScript API key (Places API + Maps JavaScript API enabled).
# Restrict it by HTTP referrer to https://cmd.mbfdhub.com/* (and localhost for dev).
# Leave blank to run with the built-in "add a Maps key" placeholder — the rest of
# the app (board, transcription) works fully without it.
VITE_GOOGLE_MAPS_API_KEY=

# Google Maps Map ID (required for Advanced Markers). Optional; a default vector
# map is used if blank.
VITE_GOOGLE_MAPS_MAP_ID=

# Base URL of the cmd-api transcription gateway.
# Local dev:  http://127.0.0.1:8200
# Production: https://cmd-api.mbfdhub.com
VITE_CMD_API_URL=http://127.0.0.1:8200

# Default map center / zoom (Miami Beach City Hall). Used before an address is set.
VITE_MAP_DEFAULT_LAT=25.7907
VITE_MAP_DEFAULT_LNG=-80.1300
VITE_MAP_DEFAULT_ZOOM=13
