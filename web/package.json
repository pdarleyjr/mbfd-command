{
  "name": "mbfd-command-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "MBFD Command — touchscreen-first incident command board (frontend)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
