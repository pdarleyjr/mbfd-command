# ── Node / Vite (web) ────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local
.vite/
web/stats.html
web/test-results/
web/playwright-report/
web/coverage/

# ── Env & secrets (deny by default) ──────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets/
.dev.vars

# ── Python / FastAPI (api) ───────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ── Local data (SQLite incident store) ───────────────────────────────
*.sqlite
*.sqlite3
*.db
api/data/
api/tests/fixtures/radio/*.wav
api/tests/fixtures/radio/manifest.jsonl
data/stt-benchmark.json

# ── Editor / OS ──────────────────────────────────────────────────────
