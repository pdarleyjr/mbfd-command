# cmd-api (transcription gateway) configuration. Copy to `.env` for local dev.
# All vars are prefixed CMD_.

# Speech-to-text — speaches / faster-whisper (OpenAI-compatible).
# On the GMKtec, the dedicated cmd-whisper container is reachable on the docker net.
CMD_WHISPER_URL=http://cmd-whisper:8000
CMD_WHISPER_MODEL=Systran/faster-distil-whisper-small.en
CMD_WHISPER_LANGUAGE=en
CMD_STT_BACKEND=speaches
CMD_STT_MODEL_PROVISION_ENABLED=true

# LLM radio parser — Ollama (warm qwen3.6:35b on the box).
# From a container, the host Ollama is typically host.docker.internal:11434.
CMD_OLLAMA_URL=http://host.docker.internal:11434
CMD_OLLAMA_MODEL=qwen3.6:35b

# SQLite incident store (path inside the container/volume).
CMD_DB_PATH=data/mbfd_command.sqlite

# CORS allow-list for the REST API (local dev origins). Production is same-origin.
CMD_ALLOWED_ORIGINS=http://localhost:5180,http://127.0.0.1:5180

# Single-origin deploy: absolute path to the built SPA (web/dist) to serve at "/".
# Leave blank for API-only (local dev with the Vite dev server).
CMD_STATIC_DIR=

# Safety guard: the WebSocket hub is process-local until a shared broker exists.
CMD_UVICORN_WORKERS=1
CMD_REALTIME_V2=true

# PulsePoint live incident feed proxy used by the top-left command card.
CMD_PULSEPOINT_URL=https://pulsepoint-proxy.pdarleyjr.workers.dev/incidents
CMD_PULSEPOINT_CACHE_TTL_S=15
CMD_PULSEPOINT_ACTIVE_POLL_S=15
CMD_PULSEPOINT_IDLE_POLL_S=45
CMD_PULSEPOINT_CLEAR_GRACE_S=90
CMD_PULSEPOINT_REQUIRED_MISSES=2
CMD_PULSEPOINT_MONITOR_ENABLED=true

# Segmentation tuning (sensible defaults; override only if needed).
CMD_TRANSCRIPT_PARTIALS_ENABLED=false
CMD_PARTIAL_INTERVAL_S=2.5
CMD_ENDPOINT_SILENCE_MS=450
CMD_MAX_SEGMENT_S=8
CMD_MIN_SEGMENT_MS=250
CMD_AUDIO_PRE_ROLL_MS=200
CMD_VAD_MODE=2
CMD_FINAL_QUEUE_SIZE=4
CMD_ENRICHMENT_QUEUE_SIZE=8
CMD_TRANSCRIPTION_LEASE_TTL_S=10
